// =============================================================================
// schema.prisma — Company Website (Phiên bản tinh gọn)
// Stack : NestJS + Prisma v6 + PostgreSQL
// Tables: 16 bảng
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

/// Phân quyền tài khoản quản trị
enum Role {
  ADMIN // Toàn quyền CMS
  EDITOR // Chỉ quản lý nội dung
}

/// Loại nội dung trang Giới thiệu
enum IntroSectionType {
  GENERAL // Giới thiệu chung
  FIELDS // Lĩnh vực hoạt động
  VISION // Tầm nhìn
  MISSION // Sứ mệnh
  CORE_VALUES // Giá trị cốt lõi
}

/// Loại danh mục sản phẩm
enum ProductCategoryType {
  COMMERCIAL // Sản phẩm thương mại
  INDUSTRIAL // Sản phẩm công nghệ công nghiệp
}

/// Lĩnh vực giải pháp (thay thế bảng solution_categories)
enum SolutionFieldType {
  TELECOM // Chuyên ngành viễn thông
  IT // Công nghệ thông tin
  DIGITAL_TRANSFORM // Chuyển đổi số
}

/// Chuyên mục tin tức (thay thế bảng news_categories)
enum NewsCategory {
  COMPANY // Tin tức công ty
  INDUSTRY // Tin tức ngành
  EVENT // Sự kiện
  TECH // Công nghệ
}

/// Phân loại đối tác
enum PartnerType {
  CUSTOMER // Khách hàng
  PARTNER // Đối tác
}

// =============================================================================
// NHÓM 1 — SYSTEM & ADMIN
// =============================================================================

/// Tài khoản quản trị CMS
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         Role     @default(EDITOR)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  news News[]

  @@map("users")
}

// =============================================================================
// NHÓM 2 — TRANG CHỦ
// =============================================================================

/// Slideshow banner trang chủ
/// Lưu thẳng image_url thay vì FK → media_files
model HomeSlideshow {
  id         String   @id @default(uuid())
  titleVi    String   @map("title_vi")
  titleEn    String?  @map("title_en")
  subtitleVi String?  @map("subtitle_vi") // có thể chứa HTML
  subtitleEn String?  @map("subtitle_en")
  ctaVi      String?  @map("cta_vi") // ← thêm mới: "Giới thiệu"
  ctaEn      String?  @map("cta_en") // ← thêm mới: "Learn more"
  imageUrl   String   @map("image_url")
  linkUrl    String?  @map("link_url")
  order      Int      @default(0)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("home_slideshows")
}

/// Video nhúng YouTube trên trang chủ
model HomeVideo {
  id           String   @id @default(uuid())
  titleVi      String   @map("title_vi")
  titleEn      String?  @map("title_en")
  youtubeUrl   String   @map("youtube_url")
  thumbnailUrl String?  @map("thumbnail_url")
  order        Int      @default(0)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("home_videos")
}

// =============================================================================
// NHÓM 3 — GIỚI THIỆU
// =============================================================================

/// Các mục nội dung trang Giới thiệu
/// type là enum: GENERAL | FIELDS | VISION | MISSION | CORE_VALUES
model CompanyIntroSection {
  id        String           @id @default(uuid())
  type      IntroSectionType @unique
  titleVi   String           @map("title_vi")
  titleEn   String?          @map("title_en")
  contentVi String           @map("content_vi") @db.Text
  contentEn String?          @map("content_en") @db.Text
  order     Int              @default(0)
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@map("company_intro_sections")
}

/// Sơ đồ cơ cấu tổ chức (cây phân cấp, self-referencing)
model OrganizationNode {
  id         String  @id @default(uuid())
  parentId   String? @map("parent_id")
  titleVi    String  @map("title_vi")
  titleEn    String? @map("title_en")
  personName String? @map("person_name")
  avatarUrl  String? @map("avatar_url")
  order      Int     @default(0)

  // Self-referencing: parent_id = null là node gốc
  parent   OrganizationNode?  @relation("OrgTree", fields: [parentId], references: [id])
  children OrganizationNode[] @relation("OrgTree")

  @@map("organization_nodes")
}

/// Lịch sử hình thành và phát triển (theo mốc năm)
model CompanyHistory {
  id        String   @id @default(uuid())
  year      Int
  titleVi   String   @map("title_vi")
  titleEn   String?  @map("title_en")
  contentVi String   @map("content_vi") @db.Text
  contentEn String?  @map("content_en") @db.Text
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("company_histories")
}

/// Thông điệp của Tổng Giám đốc
model CeoMessage {
  id         String   @id @default(uuid())
  ceoName    String   @map("ceo_name")
  ceoTitleVi String   @map("ceo_title_vi")
  ceoTitleEn String?  @map("ceo_title_en")
  contentVi  String   @map("content_vi") @db.Text
  contentEn  String?  @map("content_en") @db.Text
  avatarUrl  String?  @map("avatar_url")
  isActive   Boolean  @default(true) @map("is_active")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("ceo_messages")
}

/// Khách hàng & Đối tác
model Partner {
  id         String      @id @default(uuid())
  name       String
  logoUrl    String      @map("logo_url")
  websiteUrl String?     @map("website_url")
  type       PartnerType @default(PARTNER)
  order      Int         @default(0)
  isActive   Boolean     @default(true) @map("is_active")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@map("partners")
}

// =============================================================================
// NHÓM 4 — SẢN PHẨM & DỰ ÁN
// =============================================================================

/// Danh mục sản phẩm (Thương mại / Công nghiệp)
model ProductCategory {
  id           String              @id @default(uuid())
  nameVi       String              @map("name_vi")
  nameEn       String?             @map("name_en")
  slug         String              @unique
  categoryType ProductCategoryType @map("category_type")
  order        Int                 @default(0)
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  // Relations
  products Product[]

  @@map("product_categories")
}

/// Sản phẩm
/// thumbnailUrl lưu thẳng URL, không FK → media_files
/// Muốn thêm nhiều ảnh sau này thì thêm bảng product_images
model Product {
  id            String   @id @default(uuid())
  categoryId    String   @map("category_id")
  nameVi        String   @map("name_vi")
  nameEn        String?  @map("name_en")
  slug          String   @unique
  descriptionVi String   @map("description_vi") @db.Text
  descriptionEn String?  @map("description_en") @db.Text
  thumbnailUrl  String?  @map("thumbnail_url")
  isActive      Boolean  @default(true) @map("is_active")
  order         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  category ProductCategory @relation(fields: [categoryId], references: [id])
  specs    ProductSpec[]

  @@map("products")
}

/// Thông số kỹ thuật sản phẩm (dạng label/value, song ngữ)
model ProductSpec {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  labelVi   String  @map("label_vi") // vd: "Công suất"
  labelEn   String? @map("label_en") // vd: "Power"
  valueVi   String  @map("value_vi") // vd: "100W"
  valueEn   String? @map("value_en") // vd: "100W"
  order     Int     @default(0)

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_specs")
}

/// Dự án tiêu biểu
model Project {
  id            String   @id @default(uuid())
  nameVi        String   @map("name_vi")
  nameEn        String?  @map("name_en")
  slug          String   @unique
  clientName    String?  @map("client_name")
  year          Int?
  descriptionVi String   @map("description_vi") @db.Text
  descriptionEn String?  @map("description_en") @db.Text
  thumbnailUrl  String?  @map("thumbnail_url")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("projects")
}

// =============================================================================
// NHÓM 5 — GIẢI PHÁP & DỊCH VỤ
// =============================================================================

/// Giải pháp — dùng enum fieldType thay vì bảng solution_categories riêng
model Solution {
  id           String            @id @default(uuid())
  fieldType    SolutionFieldType @map("field_type")
  titleVi      String            @map("title_vi")
  titleEn      String?           @map("title_en")
  slug         String            @unique
  contentVi    String            @map("content_vi") @db.Text
  contentEn    String?           @map("content_en") @db.Text
  thumbnailUrl String?           @map("thumbnail_url")
  isActive     Boolean           @default(true) @map("is_active")
  order        Int               @default(0)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  @@map("solutions")
}

/// Dịch vụ
model Service {
  id        String   @id @default(uuid())
  titleVi   String   @map("title_vi")
  titleEn   String?  @map("title_en")
  slug      String   @unique
  contentVi String   @map("content_vi") @db.Text
  contentEn String?  @map("content_en") @db.Text
  iconUrl   String?  @map("icon_url")
  isActive  Boolean  @default(true) @map("is_active")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("services")
}

// =============================================================================
// NHÓM 6 — TIN TỨC
// =============================================================================

/// Bài viết tin tức — dùng enum category thay vì bảng news_categories riêng
model News {
  id           String       @id @default(uuid())
  authorId     String       @map("author_id")
  category     NewsCategory
  titleVi      String       @map("title_vi")
  titleEn      String?      @map("title_en")
  slug         String       @unique
  contentVi    String       @map("content_vi") @db.Text
  contentEn    String?      @map("content_en") @db.Text
  thumbnailUrl String?      @map("thumbnail_url")
  isPublished  Boolean      @default(false) @map("is_published")
  publishedAt  DateTime?    @map("published_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  // Relations
  author User @relation(fields: [authorId], references: [id])

  @@map("news")
}

// =============================================================================
// NHÓM 7 — LIÊN HỆ
// =============================================================================

/// Thông tin liên hệ công ty (thường chỉ có 1 record)
model ContactInfo {
  id          String   @id @default(uuid())
  addressVi   String   @map("address_vi")
  addressEn   String?  @map("address_en")
  phone       String
  email       String
  mapEmbedUrl String?  @map("map_embed_url") @db.Text
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("contact_info")
}

/// Form liên hệ gửi từ khách hàng
model ContactSubmission {
  id        String   @id @default(uuid())
  fullName  String   @map("full_name")
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_submissions")
}
